print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","","    func stopInventory() {","        let result = RFIDBleManager.shared.stopInventory()","        print(result.code == .success ? \"Inventory stopped\" : \"\\(result.message ?? \"stopInventory failed\")\")","    }","","    func setConfig() {","        var res = RFIDBleManager.shared.setPower(20)","        print(res.code == .success ? \"setPower success\" : \"\\(res.message ?? \"setPower failed\")\")","","        res = RFIDBleManager.shared.setRFLink(RFIDRFLink.Gen2X_Miller8_160KHz.rawValue)","        print(res.code == .success ? \"setRFLinkMode success\" : \"\\(res.message ?? \"setRFLinkMode failed\")\")","","        res = RFIDBleManager.shared.setMemoryBank(RFIDMemoryBank(bank: RFIDMemoryBank.InventoryBank.EPC_TID.rawValue))","        print(res.code == .success ? \"setMemoryBank success\" : \"\\(res.message ?? \"setMemoryBank failed\")\")","    }","}"],"fileName":"InventoryManager.swift","highlights":[{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37}],"syntax":"swift","identifier":"inventory-tags-05.swift","type":"file","fileType":"swift"},"connect-device-04.swift":{"fileName":"ViewController.swift","syntax":"swift","fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"highlights":[{"line":10},{"line":11},{"line":12},{"line":13}],"identifier":"connect-device-04.swift","type":"file"},"inventory-tags-02.swift":{"content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(filter: nil)","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"fileName":"InventoryManager.swift","highlights":[{"line":17},{"line":18},{"line":19},{"line":20},{"line":21}],"syntax":"swift","identifier":"inventory-tags-02.swift","type":"file","fileType":"swift"},"connect-device-03.swift":{"highlights":[{"line":37},{"line":38},{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}],"syntax":"swift","fileType":"swift","identifier":"connect-device-03.swift","fileName":"ViewController.swift","type":"file","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"]},"inventory-tags-03.swift":{"content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"type":"file","syntax":"swift","highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"fileType":"swift","identifier":"inventory-tags-03.swift","fileName":"InventoryManager.swift"},"placeholder-image.png":{"identifier":"placeholder-image.png","variants":[{"url":"\/images\/com.rfid.RFIDManager\/placeholder-image.png","traits":["1x","light"]}],"alt":"RFIDManager Getting Started","type":"image"}}}