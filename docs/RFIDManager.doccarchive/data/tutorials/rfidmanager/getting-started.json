e":"swift"}],"paths":["\/tutorials\/rfidmanager\/getting-started"]}],"kind":"project","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"categoryPathComponent":"Meet-RFIDManager","role":"project","category":"RFIDManager","title":"Getting Started"},"references":{"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager#Import-SDK-using-Swift-Package-Manager":{"type":"section","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager#Import-SDK-using-Swift-Package-Manager","kind":"section","url":"\/tutorials\/rfidmanager\/import-rfidmanager#Import-SDK-using-Swift-Package-Manager","abstract":[{"type":"text","text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import"}],"title":"Import SDK using Swift Package Manager","role":"pseudoSymbol"},"connect-device-04.swift":{"content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"type":"file","fileName":"ViewController.swift","syntax":"swift","fileType":"swift","highlights":[{"line":10},{"line":11},{"line":12},{"line":13}],"identifier":"connect-device-04.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager":{"estimatedTime":"5min","type":"topic","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager","kind":"project","title":"Import RFIDManager to Project","url":"\/tutorials\/rfidmanager\/import-rfidmanager","abstract":[{"type":"text","text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import"}],"role":"project"},"connect-device-05.swift":{"type":"file","highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}],"identifier":"connect-device-05.swift","syntax":"swift","fileName":"ViewController.swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"fileType":"swift"},"inventory-tags-03.swift":{"type":"file","highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"identifier":"inventory-tags-03.swift","syntax":"swift","fileName":"InventoryManager.swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"fileType":"swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Getting-Started":{"estimatedTime":"20min","type":"top