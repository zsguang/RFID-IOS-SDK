DBleManager.shared.setRFLink(RFIDRFLink.Gen2X_Miller8_160KHz.rawValue)","        print(res.code == .success ? \"setRFLinkMode success\" : \"\\(res.message ?? \"setRFLinkMode failed\")\")","","        res = RFIDBleManager.shared.setMemoryBank(RFIDMemoryBank(bank: RFIDMemoryBank.InventoryBank.EPC_TID.rawValue))","        print(res.code == .success ? \"setMemoryBank success\" : \"\\(res.message ?? \"setMemoryBank failed\")\")","    }","}"],"identifier":"inventory-tags-05.swift","syntax":"swift","fileType":"swift","fileName":"InventoryManager.swift","highlights":[{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37}]},"inventory-tags-02.swift":{"highlights":[{"line":17},{"line":18},{"line":19},{"line":20},{"line":21}],"type":"file","fileType":"swift","syntax":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(filter: nil)","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"identifier":"inventory-tags-02.swift","fileName":"InventoryManager.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Getting-Started":{"type":"topic","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Getting-Started","role":"project","estimatedTime":"20min","title":"Getting Started","kind":"project","url":"\/tutorials\/rfidmanager\/getting-started","abstract":[{"type":"text","text":"This tutorial will guide you through the basic usage of RFIDManager SDK, including connecting devices and inventorying tags"}]},"placeholder-image.png":{"type":"image","identifier":"placeholder-image.png","alt":"RFIDManager Getting Started","variants":[{"url":"\/images\/com.rfid.RFIDManager\/placeholder-image.png","traits":["1x","light"]}]},"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager/Getting-Started":{"type":"topic","kind":"article","title":"Getting Started","role":"article","url":"\/tutorials\/meet-rfidmanager\/getting-started","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager\/Getting-Started","abstract":[]},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager#Import-SDK-using-Swift-Package-Manager":{"type":"section","role":"pseudoSymbol","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager#Import-SDK-using-Swift-Package-Manager","title":"Import SDK using Swift Package Manager","url":"\/tutorials\/rfidmanager\/import-rfidmanager#Import-SDK-using-Swift-Package-Manager","abstract":[{"type":"text","text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import"}],"kind":"section"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Getting-Started#Connect-Bluetooth-RFID-Device":{"type":"section","role":"pseudoSymbol","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Getting-Started#Connect-Bluetooth-RFID-Device","title":"Connect Bluetooth RFID Device","url":"\/tutorials\/rfidmanager\/getting-started#Connect-Bluetooth-RFID-Device","abstract":[{"type":"text","text":"This tutorial will guide you through the basic usage of RFIDManager SDK, including connecting devices and inventorying tags"}],"kind":"section"},"connect-device-05.swift":{"type":"file","highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}],"identifier":"connect-device-05.swift","fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"fileName":"ViewController.swift","syntax":"swift"},"inventory-tags-03.swift":{"type":"file","highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"identifier":"inventory-tags-03.swift","fileType":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"fileName":"InventoryManager.swift","syntax":"swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager":{"type":"topic","role":"project","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager","estimatedTime":"5min","title":"Import RFIDManager to Project","abstract":[{"text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import","type":"text"}],"url":"\/tutorials\/rfidmanager\/import-rfidmanager","kind":"project"},"inventory-tags-01.swift":{"highlights":[],"type":"file","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","}"],"fileType":"swift","syntax":"swift","identifier":"inventory-tags-01.swift","fileName":"InventoryManager.swift"},"connect-device-01.swift":{"content":["import RFIDManager","import UIKit","","class ViewController: UIViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","","        \/\/ RFIDBleManager.shared is the singleton object of the SDK","        \/\/ RFIDBleManager.shared 是 SDK 的单例对象","        let manager = RFIDBleManager.shared","    }","}",""],"fileName":"ViewController.swift","type":"file","identifier":"connect-device-01.swift","syntax":"swift","fileType":"swift","highlights":[]},"connect-device-04.swift":{"type":"file","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"identifier":"connect-device-04.swift","syntax":"swift","fileType":"swift","fileName":"ViewController.swift","highlights":[{"line":10},{"line":11},{"line":12},{