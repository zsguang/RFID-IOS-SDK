wift"},"variants":[{"paths":["\/tutorials\/rfidmanager\/getting-started"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"Getting Started","categoryPathComponent":"Meet-RFIDManager","role":"project","category":"RFIDManager"},"kind":"project","references":{"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager#Local-SDK-File-Import":{"kind":"section","url":"\/tutorials\/rfidmanager\/import-rfidmanager#Local-SDK-File-Import","type":"section","abstract":[{"type":"text","text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import"}],"role":"pseudoSymbol","title":"Local SDK File Import","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager#Local-SDK-File-Import"},"connect-device-05.swift":{"identifier":"connect-device-05.swift","fileName":"ViewController.swift","syntax":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"type":"file","highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}],"fileType":"swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/Import-RFIDManager#Import-SDK-using-Swift-Package-Manager":{"kind":"section","url":"\/tutorials\/rfidmanager\/import-rfidmanager#Import-SDK-using-Swift-Package-Manager","type":"section","abstract":[{"type":"text","text":"This tutorial introduces two methods to import RFIDManager into your project: Swift Package Manager and local file import"}],"role":"pseudoSymbol","title":"Import SDK using Swift Package Manager","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/Import-RFIDManager#Import-SDK-using-Swift-Packag