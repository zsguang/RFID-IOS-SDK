osition":"trailing"}]},{"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up tag data callback to continuously receive tag information during inventory"}]}],"code":"inventory-tags-01.swift","caption":[],"runtimePreview":null,"media":null,"type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"Start RFID tag inventory. The inventoried tags will be returned in the callback"}],"type":"paragraph"}],"code":"inventory-tags-02.swift","caption":[{"inlineContent":[{"text":"Tag data callback can also be set via the tagInfoListBlock parameter in the start inventory method, with the same effect as step one","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":null,"type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"When starting inventory, you can pass filter and inventoryParam parameters to implement special functions"}],"type":"paragraph"}],"code":"inventory-tags-03.swift","caption":[{"inlineContent":[{"type":"text","text":"For example, filter tags with EPC starting with "},{"type":"strong","inlineContent":[{"text":"1111222233334444","type":"text"}]},{"type":"text","text":", and report each tag only once"}],"type":"paragraph"}],"runtimePreview":null,"media":null,"type":"step"},{"caption":[],"media":null,"code":"inventory-tags-04.swift","content":[{"inlineContent":[{"type":"text","text":"When you need to stop inventory, call the stop inventory method"}],"type":"paragraph"}],"runtimePreview":null,"type":"step"},{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, set power to 20, set link parameter to Gen2X_Miller8_160KHz, set inventory data area to EPC+TID"}]}],"media":null,"code":"inventory-tags-05.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can modify module configuration as needed. Note that RFID module configuration cannot be modified during inventory"}]}],"runtimePreview":null,"type":"step"}],"anchor":"Inventory-RFID-Tag