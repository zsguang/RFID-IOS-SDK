swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"syntax":"swift","fileName":"ViewController.swift","highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}]},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager":{"kind":"project","title":"导入 RFIDManager 到项目","abstract":[{"text":"本教程介绍将 RFIDManager 导入项目的两种方法：Swift Package Manager 和本地文件引入","type":"text"}],"url":"\/tutorials\/rfidmanager\/--rfidmanager","type":"topic","role":"project","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager","estimatedTime":"5min"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/----":{"type":"topic","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/----","role":"project","estimatedTime":"20min","title":"快速开始","kind":"project","url":"\/tutorials\/rfidmanager\/----","abstract":[{"text":"本教程将指导您完成 RFIDManager SDK 的基本使用，包括连接设备和盘点标签","type":"text"}]},"inventory-tags-03.swift":{"highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"type":"file","fileType":"swift","syntax":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"identifier":"inventory-tags-03.swift","fileName":"InventoryManager.swift"},"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager-zh/RFIDManager---":{"kind":"article","title":"RFIDManager 基础","abstract":[],"url":"\/tutorials\/meet-rfidmanager-zh\/rfidmanager---","type":"topic","role":"article","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager-zh\/RFIDManager---"},"inventory-tags-01.swift":{"type":"file","highlights":[],"identifier":"inventory-tags-01.swift","fileType":"swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","}"],"fileName":"InventoryManager.swift","syntax":"swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager#SDK-%E6%9C%AC%E5%9C%B0%E6%96%87%E4%BB%B6%E5%BC%95%E5%85%A5":{"type":"section","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager#SDK-%E6%9C%AC%E5%9C%B0%E6%96%87%E4%B