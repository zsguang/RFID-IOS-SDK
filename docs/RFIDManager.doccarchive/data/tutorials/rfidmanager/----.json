}","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"identifier":"connect-device-03.swift","fileName":"ViewController.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87":{"type":"section","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87","role":"pseudoSymbol","title":"连接 RFID 蓝牙设备","kind":"section","url":"\/tutorials\/rfidmanager\/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87","abstract":[{"text":"本教程将指导您完成 RFIDManager SDK 的基本使用，包括连接设备和盘点标签","type":"text"}]}}}