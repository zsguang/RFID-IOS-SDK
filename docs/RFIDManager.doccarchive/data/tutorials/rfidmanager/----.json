ock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"fileType":"swift","type":"file","identifier":"connect-device-05.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87":{"kind":"section","url":"\/tutorials\/rfidmanager\/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87","type":"section","abstract":[{"type":"text","text":"本教程将指导您完成 RFIDManager SDK 的基本使用，包括连接设备和盘点标签"}],"role":"pseudoSymbol","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/----#%E8%BF%9E%E6%8E%A5-RFID-%E8%93%9D%E7%89%99%E8%AE%BE%E5%A4%87","title":"连接 RFID 蓝牙设备"},"connect-device-02.swift":{"content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == 