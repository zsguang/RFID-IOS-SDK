t-rfidmanager-zh\/----","type":"topic","role":"article","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager-zh\/----"},"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager-zh":{"identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager-zh","type":"topic","title":"初识 RFIDManager","role":"overview","url":"\/tutorials\/meet-rfidmanager-zh","kind":"overview","abstract":[{"text":"这个教程将展示如何将 RFIDManager 库导入到您的项目中，并简单介绍如何使用它","type":"text"}]},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK":{"kind":"section","title":"使用Swift Package Manager引入 SDK","abstract":[{"type":"text","text":"本教程介绍将 RFIDManager 导入项目的两种方法：Swift Package Manager 和本地文件引入"}],"url":"\/tutorials\/rfidmanager\/--rfidmanager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK"},"connect-device-04.swift":{"content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"identifier":"connect-device-04.swift","fileName":"ViewController.swift","type":"file","syntax":"swift","fileType":"swift","highlights":[{"line":10},{"line":11},{"line":12},{"line":13}]},"connect-device-02.swift":{"type":"file","highlights":[{"line":1},{"line":6},{"line":7},{"line":10},{"line":12},{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34}],"identifier":"connect-device-02.swift","fileType":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","clas