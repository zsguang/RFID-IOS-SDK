ata 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"highlights":[{"line":10},{"line":11},{"line":12},{"line":13}],"fileType":"swift","identifier":"connect-device-04.swift","type":"file","fileName":"ViewController.swift"},"connect-device-03.swift":{"syntax":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"highlights":[{"line":37},{"line":38},{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49},{"line":50}],"fileType":"swift","identifier":"connect-device-03.swift","type":"file","fileName":"ViewController.swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK":{"type":"section","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK","kind":"section","title":"使用Swift Package Manager引入 SDK","url":"\/tutorials\/rfidmanager\/--rfidmanager#%E4%BD%BF%E7%94%A8Swift-Package-Manager%E5%BC%95%E5%85%A5-SDK","abstract":[{"type":"text","text":"本教程介绍将 RFIDManager 导入项目的两种方法：Swift Package Manager 和本地文件引入"}],"role":"pseudoSymbol"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager#SDK-%E6%9C%AC%E5%9C%B0%E6%96%87%E4%BB%B6%E5%BC%95%E5%85%A5":{"type":"section","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager#SDK-%E6%9C%AC%E5%9C%B0%E6%96%87%E4%BB%B6%E5%BC%95%E5%85%A5","kind":"section","title":"SDK 本地文件引入","url":"\/tutorials\/rfidmanager\/--rfidmanager#SDK-%E6%9C%AC%E5%9C%B0%E6%96%87%E4%BB%B6%E5%BC%95%E5%85%A5","abstract":[{"type":"text","text":"本教程介绍将 RFIDManager 导入项目的两种方法：Swift Package Manager 和本地文件引入"}],"role":"pseudoSymbol"},"connect-device-05.swift":{"syntax":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","","        RFIDBleManager.shared.setConnectStateUpdateBlock { peripheral, state in","            print(\"Device: \\(peripheral.name ?? \"Unknown\"), State: \\(state)\")","        }","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","","    func stopScanning() {","        \/\/ Stop scanning for peripherals","        \/\/ 停止扫描外设","        RFIDBleManager.shared.stopForPeripherals()","    }","","    func connectToDevice(_ peripheral: CBPeripheral) {","        RFIDBleManager.shared.connectPeripheral(","            peripheral: peripheral,","            didConnectBlock: { connectedPeripheral in","                print(\"Successfully connected: \\(connectedPeripheral.name ?? \"Unknown\")\")","            },","            didFailToConnectBlock: { failedPeripheral, error in","                print(\"Connection failed: \\(failedPeripheral.name ?? \"Unknown\") \" ","                    + \"Error: \\(error?.localizedDescription ?? \"Unknown error\")\"","                )","            }","        )","    }","}"],"highlights":[{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46}],"fileType":"swift","identifier":"connect-device-05.swift","type":"file","fileName":"ViewController.swift"},"inventory-tags-03.swift":{"fileName":"InventoryManager.swift","content":["import Foundation","import RFIDManager","","class InventoryManager {","    func initInventory() {","        \/\/ Set tag data callback","        \/\/ 设置标签数据回调","        RFIDBleManager.shared.setTagInfoListBlock { tagList in","            print(\"Received \\(tagList.count) tags\")","            \/\/ Process tag data in callback","            \/\/ 可在回调中处理标签数据","            for tag in tagList {","                print(\"EPC: \\(tag.description)\")","            }","        }","    }","","    func startInventory() {","        let result = RFIDBleManager.shared.startInventory(","            filter: RFIDFilter(","                enable: true, ","                bank: RFIDBank.EPC.rawValue,    \/\/ Filter EPC memory bank","                offset: 32,                     \/\/ Start from bit 32 (skip PC+CRC)","                length: 64,                     \/\/ Filter 64 bits (4 words)","                data: \"1111222233334444\"        \/\/ Filter data in hex","            ),","            inventoryParam: RFIDInventoryParam(unique: true)","        )","        print(result.code == .success ? \"Inventory started\" : \"\\(result.message ?? \"startInventory failed\")\")","    }","}"],"highlights":[{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"fileType":"swift","identifier":"inventory-tags-03.swift","type":"file","syntax":"swift"},"connect-device-02.swift":{"type":"file","identifier":"connect-device-02.swift","highlights":[{"line":1},{"line":6},{"line":7},{"line":10},{"line":12},{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34}],"syntax":"swift","content":["import CoreBluetooth","import RFIDManager","import UIKit","","class ViewController: UIViewController {","    var discoveredDevices: [CBPeripheral] = []","","    override func viewDidLoad() {","        super.viewDidLoad()","    }","","    func startScanning() {","        \/\/ Start scanning for Bluetooth devices","        \/\/ 开始扫描蓝牙设备","        RFIDBleManager.shared.scanForPeripherals { peripheral, advertisementData, RSSI in","            print(\"scanForPeripherals: \\(String(describing: peripheral.name))  \\(advertisementData.description)\")","","            \/\/ Filter by manufacturer data (requires BLE firmware 2.08+)","            \/\/ The prefix of kCBAdvDataManufacturerData is 0x4720","            \/\/ 通过厂家信息过滤设备（需要蓝牙固件 2.08+）","            \/\/ kCBAdvDataManufacturerData 前缀为 0x4720","            if let data = advertisementData[\"kCBAdvDataManufacturerData\"] as? Data,","               data.count >= 2 && data[0] == 0x47 && data[1] == 0x20","            {","                print(\"kCBAdvDataManufacturerData: \\(data)\")","            } else {","                \/\/ return  \/\/ Uncomment to filter out non-matching devices","                \/\/         \/\/ 取消注释以过滤不匹配的设备","            }","","            if !self.discoveredDevices.contains(where: { $0.name == peripheral.name }) {","                self.discoveredDevices.append(peripheral)","            }","        }","    }","}",""],"fileName":"ViewController.swift","fileType":"swift"},"connect-device-01.swift":{"type":"file","identifier":"connect-device-01.swift","highlights":[],"syntax":"swift","content":["import RFIDManager","import UIKit","","class ViewController: UIViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","","        \/\/ RFIDBleManager.shared is the singleton object of the SDK","        \/\/ RFIDBleManager.shared 是 SDK 的单例对象","        let manager = RFIDBleManager.shared","    }","}",""],"fileName":"ViewController.swift","fileType":"swift"},"doc://com.rfid.RFIDManager/tutorials/RFIDManager/--RFIDManager":{"url":"\/tutorials\/rfidmanager\/--rfidmanager","type":"topic","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/RFIDManager\/--RFIDManager","title":"导入 RFIDManager 到项目","kind":"project","role":"project","abstract":[{"type":"text","text":"本教程介绍将 RFIDManager 导入项目的两种方法：Swift Package Manager 和本地文件引入"}],"estimatedTime":"5min"},"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager-zh":{"url":"\/tutorials\/meet-rfidmanager-zh","type":"topic","identifier":"doc:\/\/com.rfid.RFIDManager\/tuto