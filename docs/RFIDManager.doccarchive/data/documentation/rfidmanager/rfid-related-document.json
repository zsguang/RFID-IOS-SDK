{"primaryContentSections":[{"content":[{"type":"heading","text":"RFID Tag Data Structure","anchor":"RFID-Tag-Data-Structure","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin’s functionality is designed and developed around RFID tags. Understanding some basic information about RFID tags can help better comprehend the RFID-related features."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The basic data areas of an RFID tag are roughly as shown below:"}]},{"type":"heading","text":"Data Regions Explanation:","anchor":"Data-Regions-Explanation","level":3},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"RESERVED","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Contains two password fields: kill and access, each 32 bits long. Default password is 00000000.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"EPC","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Contains three components:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"crc: Cyclic Redundancy Check"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"pc: epc length control word"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"epc: Actual EPC user data"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The length of the epc data read during inventory is determined by the upper 5 bits of the pc value.","type":"text"},{"text":"\n","type":"text"},{"text":"Examples of epc length to pc value conversion:","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 6 words (96 bits)： 6 word = ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"0011 0"}]},{"text":"000 0000 0000 = 0x3000","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 9 words (144 bits)： 9 word = ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"0100 1"}]},{"text":"000 0000 0000 = 0x4800","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 15 words (240 bits)： 15 word = ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"0111 1"}]},{"text":"000 0000 0000 = 0x7800","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"TID","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Contains only tid data. Typically 96 bits, unique and unmodifiable.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"USER","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Contains only user data. Length varies by tag type.","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFID-related-document"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager"]]},"variants":[{"paths":["\/documentation\/rfidmanager\/rfid-related-document"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"RFIDManager"}],"roleHeading":"Article","role":"article","title":"RFID Document"},"abstract":[{"type":"text","text":"If you don’t know about RFID, this article will introduce you to some basic knowledge so that you can better understand the SDK.."}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager","doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager-FAQ"],"title":"Developing with RFIDManager","anchor":"Developing-with-RFIDManager"}],"references":{"doc://com.rfid.RFIDManager/documentation/RFIDManager/RFIDManager-FAQ":{"identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager-FAQ","kind":"article","type":"topic","role":"article","abstract":[{"type":"text","text":"This document mainly introduces some common problems you may encounter when using RFIDManager"}],"title":"RFIDManager-FAQ","url":"\/documentation\/rfidmanager\/rfidmanager-faq"},"doc://com.rfid.RFIDManager/documentation/RFIDManager":{"role":"collection","title":"RFIDManager","abstract":[{"text":"A framework for UHF RFID tag reading, writing, and management on Apple platforms.","type":"text"}],"url":"\/documentation\/rfidmanager","identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager","kind":"symbol","type":"topic"},"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager":{"identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager","kind":"overview","type":"topic","role":"overview","abstract":[{"type":"text","text":"This tutorial will guide you through importing the RFIDManager library into your project and show you how to use it."}],"title":"Meet RFIDManager","url":"\/tutorials\/meet-rfidmanager"}}}