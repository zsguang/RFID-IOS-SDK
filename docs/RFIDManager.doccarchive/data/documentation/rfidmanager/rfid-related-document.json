{"seeAlsoSections":[{"anchor":"Developing-with-RFIDManager","title":"Developing with RFIDManager","generated":true,"identifiers":["doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager","doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager-FAQ"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFID-related-document"},"kind":"article","abstract":[{"type":"text","text":"If you don’t know about RFID, this article will introduce you to some basic knowledge so that you can better understand the SDK.."}],"variants":[{"paths":["\/documentation\/rfidmanager\/rfid-related-document"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"text":"RFID Tag Data Structure","level":2,"type":"heading","anchor":"RFID-Tag-Data-Structure"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin’s functionality is designed and developed around RFID tags. Understanding some basic information about RFID tags can help better comprehend the RFID-related features."}]},{"type":"paragraph","inlineContent":[{"text":"The basic data areas of an RFID tag are roughly as shown below:","type":"text"}]},{"text":"Data Regions Explanation:","level":3,"type":"heading","anchor":"Data-Regions-Explanation"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"RESERVED","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Contains two password fields: kill and access, each 32 bits long. Default password is 00000000."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"EPC"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Contains three components:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"crc: Cyclic Redundancy Check","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"pc: epc length control word"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"epc: Actual EPC user data"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The length of the epc data read during inventory is determined by the upper 5 bits of the pc value.","type":"text"},{"text":"\n","type":"text"},{"text":"Examples of epc length to pc value conversion:","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 6 words (96 bits)： 6 word = ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"0011 0"}]},{"text":"000 0000 0000 = 0x3000","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 9 words (144 bits)： 9 word = ","type":"text"},{"type":"strong","inlineContent":[{"text":"0100 1","type":"text"}]},{"text":"000 0000 0000 = 0x4800","type":"text"},{"text":"\n","type":"text"},{"text":"For an epc length of 15 words (240 bits)： 15 word = ","type":"text"},{"inlineContent":[{"type":"text","text":"0111 1"}],"type":"strong"},{"text":"000 0000 0000 = 0x7800","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"TID"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Contains only tid data. Typically 96 bits, unique and unmodifiable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"USER","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Contains only user data. Length varies by tag type."}]}]}],"type":"orderedList"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager"]]},"sections":[],"metadata":{"modules":[{"name":"RFIDManager"}],"title":"RFID Document","role":"article","roleHeading":"Article"},"references":{"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager":{"role":"overview","identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager","kind":"overview","abstract":[{"text":"This tutorial will guide you through importing the RFIDManager library into your project and show you how to use it.","type":"text"}],"url":"\/tutorials\/meet-rfidmanager","title":"Meet RFIDManager","type":"topic"},"doc://com.rfid.RFIDManager/documentation/RFIDManager/RFIDManager-FAQ":{"type":"topic","role":"article","identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager-FAQ","url":"\/documentation\/rfidmanager\/rfidmanager-faq","abstract":[{"text":"This document mainly introduces some common problems you may encounter when using RFIDManager","type":"text"}],"title":"RFIDManager-FAQ","kind":"article"},"doc://com.rfid.RFIDManager/documentation/RFIDManager":{"kind":"symbol","abstract":[{"type":"text","text":"A framework for UHF RFID tag reading, writing, and management on Apple platforms."}],"type":"topic","title":"RFIDManager","url":"\/documentation\/rfidmanager","role":"collection","identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager"}}}