长度为 6 个字 (96 bit)： 6 字 = 0011 0000 0000 0000 = 0x3000","type":"text"},{"type":"text","text":"\n"},{"text":"epc 长度为 9 个字 (144 bit)： 9 字 = 0100 1000 0000 0000 = 0x4800","type":"text"},{"text":"\n","type":"text"},{"type":"text","text":"epc 长度为 15 个字 (240 bit)： 15 字 = 0111 1000 0000 0000 = 0x7800"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"TID 区域均为 tid 数据。一般来说，tid 长度为 96 bit, 是唯一且无法修改的","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"USER 区域均为 user 数据，其长度取决于具体标签，不同类型标签的 USER 区域容量可能不同","type":"text"}],"type":"paragraph"}]}]}]}],"identifier":{"url":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFID-----","interfaceLanguage":"swift"},"references":{"doc://com.rfid.RFIDManager/tutorials/Meet-RFIDManager-zh":{"identifier":"doc:\/\/com.rfid.RFIDManager\/tutorials\/Meet-RFIDManager-zh","type":"topic","title":"初识 RFIDManager","role":"overview","url":"\/tutorials\/meet-rfidmanager-zh","kind":"overview","abstract":[{"text":"这个教程将展示如何将 RFIDManager 库导入到您的项目中，并简单介绍如何使用它","type":"text"}]},"doc://com.rfid.RFIDManager/documentation/RFIDManager/RFIDManager----":{"kind":"article","title":"RFIDManager 中文文档","abstract":[{"type":"text","text":"Apple 全平台的 RFID 标签读写管理框架"}],"url":"\/documentation\/rfidmanager\/rfidmanager----","type":"topic","role":"collectionGroup","identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager----"},"doc://com.rfid.RFIDManager/documentation/RFIDManager/RFIDManager-----":{"identifier":"doc:\/\/com.rfid.RFIDManager\/documentation\/RFIDManager\/RFIDManager-----","type":"topic","title":"RFIDManager常见问题","role":"article","url":"\/documentation\/rfidmanager\/rfidmanager-----","kind":"article","abstract":[{"type":"text","text":"这篇文章主要介绍一些使用 RFIDManager 可能会遇到的常见问题"}]},"doc://com.rfid.RFIDManager/documentation/RFIDManager":{"kind":"symbol","abstract":[{"type":"text","text":"A framework for UHF RFID tag reading, writing, and management on Apple platforms."}],"type":"topic","title":"RFIDMa